{
  "name": "headlessdev",
  "version": "0.2.2",
  "description": "Secure, private browser access for AI agents. Local MCP server with read-optimized markdown extraction.",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "headlessdev": "dist/bin/headlessdev.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/bin/headlessdev.js",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build",
    "build:site": "cd hero-proto && npx vite build"
  },
  "keywords": [
    "mcp",
    "browser",
    "headless",
    "ai",
    "agent",
    "playwright",
    "claude",
    "cursor",
    "automation",
    "markdown",
    "local",
    "private",
    "security"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NETWORK101/headlessdev"
  },
  "homepage": "https://headlessdev.ai",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^9.0.0",
    "jsdom": "^24.1.3",
    "playwright": "^1.48.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
